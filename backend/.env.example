# ─── Server ──────────────────────────────────────────────
PORT=4000
BACKEND_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://matchmind:matchmind_pass@localhost:5432/matchmind"
REDIS_URL="redis://localhost:6379"

# ─── Auth ────────────────────────────────────────────────
JWT_SECRET="replace-with-64-char-random-hex-string"
JWT_REFRESH_SECRET="replace-with-another-64-char-random-hex-string"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# ─── Sports Data ─────────────────────────────────────────
SPORTRADAR_API_KEY="your-sportradar-api-key"

# ─── Media ───────────────────────────────────────────────
CLOUDINARY_URL="cloudinary://key:secret@cloud"

# ─── AI ──────────────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ─── Pro / Stripe ────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_MONTHLY="price_monthly_id"
STRIPE_PRICE_ANNUAL="price_annual_id"

# ─── Feature Flags (optional, defaults to true) ──────────
# FLAG_AI_HINTS=true
# FLAG_PRO_GATE_AI=true
# FLAG_CHAT_GIFS=true
# FLAG_LB_REALTIME=false
# FLAG_DM=false
