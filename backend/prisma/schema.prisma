generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum Sport {
  FOOTBALL
  BASKETBALL
  AMERICAN_FOOTBALL
  TENNIS
  CRICKET
  HOCKEY
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  POSTPONED
  CANCELLED
}

enum PredStatus {
  PENDING
  LOCKED
  SCORED
  VOID
}

enum Tier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  LEGEND
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPERADMIN
}

enum NotifType {
  MATCH_STARTING
  PREDICTION_LOCKED
  PREDICTION_SCORED
  RANK_CHANGED
  NEW_FOLLOWER
  SQUAD_INVITE
  LEAGUE_RESULT
  ACHIEVEMENT
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

// ─── USERS ──────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  username           String    @unique
  email              String    @unique
  emailVerified      Boolean   @default(false)
  passwordHash       String?
  displayName        String?
  avatar             String?
  bannerImage        String?
  bio                String?
  countryCode        String?
  role               UserRole  @default(USER)
  tier               Tier      @default(BRONZE)
  totalPoints        Int       @default(0)
  weeklyPoints       Int       @default(0)
  globalRank         Int?
  predAccuracy       Float     @default(0)
  totalPredictions   Int       @default(0)
  correctPredictions Int       @default(0)
  streakCurrent      Int       @default(0)
  streakBest         Int       @default(0)
  isPro              Boolean   @default(false)
  proExpiresAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastActiveAt       DateTime?

  predictions      Prediction[]
  following        Follow[]        @relation("follower")
  followers        Follow[]        @relation("following")
  leagues          LeagueMember[]
  squads           SquadMember[]
  notifications    Notification[]
  userAchievements UserAchievement[]
  chatMessages     ChatMessage[]
  reports          Report[]        @relation("reporter")
  subscription     Subscription?
  sportPreferences UserSport[]
  teamPreferences  UserTeam[]
  sessions         Session[]
}

// ─── FOLLOW SYSTEM ──────────────────────────────────────

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower",  fields: [followerId],  references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

// ─── SPORTS & COMPETITIONS ──────────────────────────────

model Competition {
  id          String   @id @default(cuid())
  name        String
  shortName   String
  sport       Sport
  logo        String?
  countryCode String?
  externalId  String?  @unique
  isActive    Boolean  @default(true)

  matches   Match[]
  standings Standing[]
}

model Team {
  id          String  @id @default(cuid())
  name        String
  shortName   String
  logo        String?
  countryCode String?
  sport       Sport
  externalId  String? @unique

  homeMatches Match[]         @relation("homeTeam")
  awayMatches Match[]         @relation("awayTeam")
  players     Player[]
  userTeams   UserTeam[]
  standings   Standing[]
}

model Player {
  id          String  @id @default(cuid())
  name        String
  position    String?
  number      Int?
  nationality String?
  photo       String?
  teamId      String?
  sport       Sport
  externalId  String? @unique

  team Team? @relation(fields: [teamId], references: [id])
}

// ─── MATCHES ────────────────────────────────────────────

model Match {
  id             String      @id
  sport          Sport
  competitionId  String
  homeTeamId     String
  awayTeamId     String
  // Denormalized convenience fields (populated on seed/import)
  homeTeamName   String
  awayTeamName   String
  homeTeamLogo   String?
  awayTeamLogo   String?
  competition    String
  stadium        String?
  // Game state
  homeScore      Int?
  awayScore      Int?
  homeScoreHT    Int?
  awayScoreHT    Int?
  status         MatchStatus @default(SCHEDULED)
  minute         Int?
  scheduledAt    DateTime
  kickedOffAt    DateTime?
  finishedAt     DateTime?
  season         String?
  externalId     String?     @unique
  aiSummary      String?

  competitionRel Competition  @relation(fields: [competitionId], references: [id])
  homeTeam       Team         @relation("homeTeam", fields: [homeTeamId], references: [id])
  awayTeam       Team         @relation("awayTeam", fields: [awayTeamId], references: [id])
  predictions    Prediction[]
  chatMessages   ChatMessage[]
  events         MatchEvent[]
}

model MatchEvent {
  id        String   @id @default(cuid())
  matchId   String
  type      String   // GOAL, YELLOW_CARD, RED_CARD, SUBSTITUTION, VAR
  minute    Int
  teamId    String?
  playerId  String?
  detail    Json?
  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])
}

// ─── PREDICTIONS ────────────────────────────────────────

model Prediction {
  id               String     @id @default(cuid())
  userId           String
  matchId          String
  homeGoals        Int
  awayGoals        Int
  firstScorerId    String?
  totalGoalsOU     String?    // "over" | "under"
  totalGoalsLine   Float?     // e.g. 2.5
  btts             Boolean?
  result           String?    // "home" | "draw" | "away"
  pointsEarned     Int?
  pointsBreakdown  Json?
  status           PredStatus @default(PENDING)
  lockedAt         DateTime?
  scoredAt         DateTime?
  createdAt        DateTime   @default(now())

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
  @@index([status])
}

// ─── LEAGUES ────────────────────────────────────────────

model League {
  id          String   @id @default(cuid())
  name        String
  description String?
  badge       String?
  inviteCode  String   @unique
  isPublic    Boolean  @default(false)
  sport       Sport?
  ownerId     String
  maxMembers  Int      @default(50)
  scoringRule Json?
  createdAt   DateTime @default(now())

  members LeagueMember[]
}

model LeagueMember {
  id        String   @id @default(cuid())
  leagueId  String
  userId    String
  points    Int      @default(0)
  rank      Int?
  joinedAt  DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
}

// ─── SQUADS ─────────────────────────────────────────────

model Squad {
  id          String   @id @default(cuid())
  name        String
  badge       String?
  description String?
  ownerId     String  @default("")
  isPrivate   Boolean  @default(true)
  createdAt   DateTime @default(now())

  members      SquadMember[]
  chatMessages ChatMessage[] @relation("squadChat")
}

model SquadMember {
  id       String   @id @default(cuid())
  squadId  String
  userId   String
  role     String   @default("member") // owner | admin | member
  points   Int      @default(0)
  joinedAt DateTime @default(now())

  squad Squad @relation(fields: [squadId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([squadId, userId])
}

// ─── CHAT ───────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  roomType  String   // "match" | "squad" | "sport"
  roomId    String   // matchId | squadId | sport name
  userId    String
  text      String?
  gifUrl    String?
  type      String   @default("text") // text | gif | system
  reactions Json     @default("{}")
  isPinned  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User   @relation(fields: [userId], references: [id])
  reports Report[]

  @@index([roomType, roomId])
  @@index([createdAt])
}

// ─── NOTIFICATIONS ──────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String    // NotifType as string for flexibility
  title     String
  message   String?
  link      String?
  payload   Json?
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

// ─── ACHIEVEMENTS ───────────────────────────────────────

model Achievement {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String
  icon        String
  rarity      String  // common | rare | epic | legendary
  pointBonus  Int     @default(0)

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

// ─── SUBSCRIPTIONS ──────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String             @unique
  plan                 String             // monthly | annual
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── REPORTS & MODERATION ───────────────────────────────

model Report {
  id         String   @id @default(cuid())
  reporterId String
  messageId  String?
  userId     String?
  reason     String
  detail     String?
  status     String   @default("pending") // pending | resolved | dismissed
  createdAt  DateTime @default(now())

  reporter User       @relation("reporter", fields: [reporterId], references: [id])
  message  ChatMessage? @relation(fields: [messageId], references: [id])
}

// ─── SUPPORT MODELS ─────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Standing {
  id            String   @id @default(cuid())
  competitionId String
  teamId        String
  season        String
  position      Int
  played        Int
  won           Int
  drawn         Int
  lost          Int
  goalsFor      Int
  goalsAgainst  Int
  points        Int
  form          String?  // e.g. "WWDLW"
  updatedAt     DateTime @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id])
  team        Team        @relation(fields: [teamId], references: [id])

  @@unique([competitionId, teamId, season])
}

model UserSport {
  userId String
  sport  Sport

  user User @relation(fields: [userId], references: [id])

  @@id([userId, sport])
}

model UserTeam {
  userId String
  teamId String

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  @@id([userId, teamId])
}
