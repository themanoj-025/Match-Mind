{
  "name": "matchmind-backend",
  "version": "1.0.0",
  "description": "MatchMind API Server - The Internet's Sports Bar",
  "main": "src/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "npm run test:up && vitest run; npm run test:down",
    "test:watch": "vitest",
    "test:up": "docker-compose -f ../docker-compose.test.yml up -d && npx prisma db push --accept-data-loss --force-reset",
    "test:down": "docker-compose -f ../docker-compose.test.yml down",
    "test:ci": "vitest run",
    "check-api": "node scripts/checkApiCoverage.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@matchmind/shared-types": "*",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.63.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "async-mutex": "^0.5.0",
    "awilix": "^13.0.5",
    "awilix-express": "^11.0.1",
    "bullmq": "^5.80.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "opossum": "^10.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "redis": "^6.0.0",
    "resend": "^6.17.2",
    "socket.io": "^4.8.3",
    "stripe": "^22.2.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mermaid-js/mermaid-cli": "^11.16.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "@types/opossum": "^8.1.9",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "nodemon": "^3.1.14",
