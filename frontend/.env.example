# ── MatchMind Environment Variables ──────────────────────
# Copy this to .env.local for local development
# Set these in Vercel Dashboard → Settings → Environment Variables

# Backend API URL (Vercel rewrites /api/* to this)
VITE_API_URL=https://matchmind-api.railway.app

# WebSocket URL (for Socket.io)
VITE_WS_URL=https://matchmind-api.railway.app

# Frontend URL (your Vercel domain)
VITE_APP_URL=https://matchmind.gg

# Analytics (PostHog - optional)
VITE_POSTHOG_KEY=

# Sentry (error tracking - optional)
VITE_SENTRY_DSN=

# Google OAuth Client ID (for frontend Google sign-in)
VITE_GOOGLE_CLIENT_ID=

# Feature Flags
VITE_FLAG_AI_HINTS=true
VITE_FLAG_CHAT_GIFS=true
VITE_FLAG_LEADERBOARD_REALTIME=true
