# Rename this file to docker-compose.override.yml to use it locally.
# It provides hot-reloading volume mounts and exposed ports for debugging.

services:
  app:
    volumes:
      - ./backend:/app
      - /app/node_modules
    ports:
      - "9229:9229" # Node.js debugger

  postgres:
    ports:
      - "5432:5432"

  redis:
    ports:
      - "6379:6379"
