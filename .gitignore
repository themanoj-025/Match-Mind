# ════════════════════════════════════════════════════════════════
#  SECRETS & ENVIRONMENT  (NEVER COMMIT THESE)
# ════════════════════════════════════════════════════════════════
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
credentials.json

# ════════════════════════════════════════════════════════════════
#  NODE.JS
# ════════════════════════════════════════════════════════════════
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ════════════════════════════════════════════════════════════════
#  BUILD ARTIFACTS
# ════════════════════════════════════════════════════════════════
dist/
dist-ssr/
build/
*.tsbuildinfo

# ════════════════════════════════════════════════════════════════
#  LOGS
# ════════════════════════════════════════════════════════════════
logs/
*.log

# ════════════════════════════════════════════════════════════════
#  IDE & EDITOR
# ════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln

# ════════════════════════════════════════════════════════════════
#  OS FILES
# ════════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
Desktop.ini

# ════════════════════════════════════════════════════════════════
#  PRISMA (generated at runtime)
# ════════════════════════════════════════════════════════════════
backend/prisma/*.tsbuildinfo

# ════════════════════════════════════════════════════════════════
